def normcol(c): return re.sub(r"[^a-z0-9]+", "", str(c).strip().lower())
def find_col(cols, candidates):
    cols_n = {normcol(c): c for c in cols}
    for cand in candidates:
        k = normcol(cand)
        if k in cols_n:
            return cols_n[k]
    for cand in candidates:
        k = normcol(cand)
        for cn, orig in cols_n.items():
            if k in cn:
                return orig
    return None

