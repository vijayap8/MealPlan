# Cache
CACHE_DIR = Path("/content/fdc_cache")
CACHE_DIR.mkdir(parents=True, exist_ok=True)

def _cache_path(prefix: str, payload: dict) -> Path:
    s = json.dumps(payload, sort_keys=True, ensure_ascii=True)
    h = hashlib.sha256(s.encode("utf-8")).hexdigest()
    return CACHE_DIR / f"{prefix}_{h}.json"

sess = requests.Session()

def cached_post(url: str, params: dict, json_body: dict, prefix: str, timeout=(10, 60), max_retries=6, pace_s=0.01):
    payload = {"url": url, "params": params, "json": json_body}
    fp = _cache_path(prefix, payload)
    if fp.exists():
        return json.loads(fp.read_text())
    for attempt in range(max_retries):
        time.sleep(pace_s)
        r = sess.post(url, params=params, json=json_body, timeout=timeout)
        if r.status_code == 429:
            time.sleep(2 ** attempt)
            continue
        r.raise_for_status()
        fp.write_text(r.text)
        return r.json()
    raise RuntimeError(f"POST failed: {url}")

def cached_get(url: str, params: dict, prefix: str, timeout=(10, 60), max_retries=6, pace_s=0.01):
    payload = {"url": url, "params": params}
    fp = _cache_path(prefix, payload)
    if fp.exists():
        try:
            return json.loads(fp.read_text())
        except Exception:
            return {"__http_status__": 404}
    for attempt in range(max_retries):
        time.sleep(pace_s)
        r = sess.get(url, params=params, timeout=timeout)
        if r.status_code == 429:
            time.sleep(2 ** attempt)
            continue
        if r.status_code == 404:
            fp.write_text(r.text)
            return {"__http_status__": 404}
        r.raise_for_status()
        fp.write_text(r.text)
        return r.json()
    raise RuntimeError(f"GET failed: {url}")

def fdc_search(query: str, page_size: int = TOP_SEARCH):
    body = {"query": query, "pageSize": page_size, "pageNumber": 1, "dataType": ALLOWED_DATA_TYPES}
    return cached_post(f"{BASE}/foods/search", params={"api_key": API_KEY}, json_body=body, prefix="match_chickpea_greek_v1")

def fdc_desc_for_id(fdcId: int) -> str:
    j = cached_get(f"{BASE}/food/{int(fdcId)}", params={"api_key": API_KEY}, prefix="desc_only_chickpea_greek_v1")
    if isinstance(j, dict) and j.get("__http_status__") == 404:
        return ""
    return (j.get("description") or "")

